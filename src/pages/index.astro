---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<!-- Tailwind CSS CDN cho trang này -->
		<script src="https://cdn.tailwindcss.com"></script>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="text-3xl font-semibold">Hello everyone!</h1>
			<!-- Nút điều hướng dùng Tailwind -->
			<div class="mt-8 flex gap-4">
				<a
					href="/blog"
					class="inline-flex items-center justify-center rounded-lg bg-black px-6 py-2.5 text-white shadow-sm ring-1 ring-black/10 hover:bg-neutral-900 hover:shadow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2 active:scale-95 transition-colors duration-200"
				>
					Blog
				</a>
				<a
					href="/about"
					class="inline-flex items-center justify-center rounded-lg border border-neutral-300 bg-white px-6 py-2.5 text-neutral-800 shadow-sm hover:bg-neutral-50 hover:border-neutral-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-2 active:scale-95 transition-colors duration-200"
				>
					Giới thiệu
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
